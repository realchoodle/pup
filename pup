#!/usr/bin/env bash

declare -A upd_days

ok=${ printf "\033[0;32m%b\033[0m" "pup:"; }
warn=${ printf "\033[0;33m%b\033[0m" "pup:"; }
bad=${ printf "\033[0;31m%b\033[0m" "pup:"; }

# The -1 asks for a current date
today="${ printf "%(%A)T" "-1"; }"
upd_days=([Wednesday]=1 [Thursday]=1 [Friday]=1)
is_upd_day="false"

# Undefined keys return empty strings 
[[ -n "${upd_days[$today]}" ]] && is_upd_day="true"

if [[ "$is_upd_day" == "true" || "$1" == "--force" ]]; then
    read -rp "$ok Have you checked for problematic updates? [y/N] " informed
else
    echo "$bad Update days are set to: ${!upd_days[*]}"
    exit 1
fi

vet() {
    local exit_status
    local -a cmd

    cmd=("$@")

    if ! command -v "${cmd[0]}" > /dev/null 2>&1; then
        echo "$bad ${cmd[0]} is not installed."
        exit 1
    fi

    echo "$ok Updating packages with: ${cmd[*]}"
    "${cmd[@]}"

    exit_status="$?"
    if [[ $exit_status -ne 0 ]]; then
        echo "$bad ${cmd[*]} failed with exit status $exit_status."
        exit 1
    fi
}

update() {
    vet paru -Syu
    vet flatpak update --user --assumeyes
    vet tldr --update
    vet rustup update
    echo "$ok Done!"
    if command -v notify-send > /dev/null 2>&1; then
        notify-send "pup" "Updates complete!"
    fi
    exit 0
}

# ${var,,} converts the variable to lowercase
case ${informed,,} in 
    "y"|"yes") 
        update ;;
    *)
        echo "$warn No packages were updated; read the news."
        echo "$warn Fetching news..."
        paru -Pw
        read -rp "$warn Things look okay? [y/N] " checkup 

        case ${checkup,,} in
            "y"|"yes") echo "$ok Starting updates!"; update ;;
            *) echo "$ok No packages were updated."; exit 0 ;;
        esac
        ;;
esac
