#!/usr/bin/env bash

ok=${ printf "\033[0;32m%b\033[0m" "pup:"; }
warn=${ printf "\033[0;33m%b\033[0m" "pup:"; }
bad=${ printf "\033[0;31m%b\033[0m" "pup:"; }

today="${ date +%A; }"
update_days=("Friday" "Wednesday")
is_update_day=false

for day in "${update_days[@]}"; do
[[ "$today" == "$day" ]] && is_update_day=true; break
done 

if [[ "$is_update_day" == "true" || "$1" == "--force" ]]; then
    read -rp "${ok} Have you checked for problematic updates? [y/N] " informed
else
    printf "%s %s %s\n" "${bad}" "Update days are set to:" "${update_days[*]}"
    exit 1
fi

function _vet {
    local cmd=("$@")
    local cmd_str="${cmd[*]}"
    local upd_msg
    upd_msg=$(printf "%s %s\n" "Updating packages with:" "${cmd_str}")

    echo "${ok} ${upd_msg}"
    # This runs each argument passed to this function
    "${cmd[@]}"

    # Error handling
    local exit_status=${?}
    if [[ ${exit_status} -ne 0 ]]; then
        printf "%s %s %s\n" "${bad}" "${cmd_str}" "failed with exit status ${exit_status}."
        exit 1
    fi
}

# Main program
case ${informed,,} in # ${var,,} converts the variable to lowercase
    "y"|"yup"|"yes") 
        _vet paru -Syu
        _vet flatpak update --user --assumeyes
        _vet tldr --update
        echo "${ok} Done! :D"
        exit 0
        ;;
    *)
        echo "${warn} No packages were updated. Read the news!"
        echo "${warn} Fetching news..."
        paru -Pw
        exit 0
        ;;
esac
