#!/usr/bin/env bash

# Colors for pup status messages
grn="\033[0;32m"
ylw="\033[0;33m"
red="\033[0;31m"
res="\033[0m" # reset color

pup_ok=$(printf "%b" "${grn}pup:${res}")
pup_bad=$(printf "%b" "${red}pup:${res}")
pup_wrn=$(printf "%b" "${ylw}pup:${res}")

today="$(date +%A)"
update_days=(Friday Wednesday)

for day in "${update_days[@]}"; do
    if [[ "$today" == "$day" ]]; then
        read -rp "${pup_ok} Have you checked for problematic updates? [y/N] " informed
    else
        printf "%s %s %s\n" "${pup_bad}" "Update days are set to:" "${update_days[*]}"
        exit 1
    fi
done 

function _vet {
    local upd_msg
    upd_msg=$(printf "%s %s\n" "Updating packages with:" "${*}")

    echo "${pup_ok} ${upd_msg}"
    # This runs each argument
    "${@}"

    # Error handling
    local exit_status=${?}
    [[ ${exit_status} == 0 ]] ||
        (printf "%s %s %s\n" "${pup_bad}" "${*}" "failed with exit status ${exit_status}." &&
        exit 1)
}

# Main program
case ${informed} in
    "y"|"Y"|"sure did"|"yup"|"yes"|"Yes"|"you're not my dad bro") 
        paru_arr=(paru -Syyuu)
        fp_arr=(flatpak update --user --assumeyes)
        tldr_arr=(tldr --update)
        _vet "${paru_arr[@]}"
        _vet "${fp_arr[@]}"
        _vet "${tldr_arr[@]}"
        echo "${pup_ok} Done! :D"
        exit 0
        ;;
    *)
        echo "${pup_wrn} No packages were updated. Read the news!"
        echo "${pup_wrn} Fetching news…"
        paru -Pw
        exit 0
        ;;
esac
